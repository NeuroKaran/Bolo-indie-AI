{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Bolo",
  "version": "1.0.0",
  "identifier": "com.bolo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bolo — Voice to Developer Prompts",
        "label": "main",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 400,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "Bolo — Voice to Developer Prompts"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}